---
import '../styles/global.css';
import SearchWidget from '../components/SearchWidget.svelte';
import AuditResult from '../components/AuditResult.svelte';
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>VestaMate — KI-Reputationsmanager für Restaurants</title>

    <!--
      Стейт-машина: inline-скрипт определяет фазу пользователя ДО первого рендера.
      Намеренно дублирует логику stateManager.js — ES-модули нельзя запустить синхронно в head.
    -->
    <script is:inline>
      (function () {
        function getCookie(n) {
          var m = document.cookie.match(
            new RegExp('(?:^|; )' + n.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '=([^;]*)')
          );
          return m ? decodeURIComponent(m[1]) : null;
        }

        var token = getCookie('access_token');
        var state = token
          ? getCookie('user_state') === 'active' ? 3 : 2
          : localStorage.getItem('place_id') ? 1 : 0;

        document.addEventListener('DOMContentLoaded', function () {
          // 1. Показываем нужный Hero-блок
          var hero = document.getElementById('hero-' + state);
          if (hero) hero.classList.remove('hidden');

          // 2. Подставляем название ресторана во все помеченные элементы
          var name = localStorage.getItem('restaurant_name') || 'Ihr Restaurant';
          document.querySelectorAll('[data-restaurant-name]').forEach(function (el) {
            el.textContent = name;
          });

          // 3. Фаза 3: асинхронно загружаем данные дашборда
          if (state === 3) {
            fetch('/api/status?access_token=' + encodeURIComponent(getCookie('access_token') || ''))
              .then(function (r) { return r.json(); })
              .then(function (d) {
                var reviewsEl = document.getElementById('status-reviews');
                var aiEl = document.getElementById('status-ai');
                if (reviewsEl) reviewsEl.textContent = d.new_reviews_7d != null ? d.new_reviews_7d : '—';
                if (aiEl) aiEl.textContent = d.last_ai_reply_status || '—';
              })
              .catch(function () {});
          }
        });
      })();
    </script>
  </head>

  <body class="bg-slate-950 text-slate-100 min-h-screen">

    <!-- ═══════════════════════════════════════════════════════
         HERO 0 — Анонимный посетитель
         Placeholder поиска. Полный SearchWidget — Этап 4.
    ════════════════════════════════════════════════════════ -->
    <section id="hero-0" class="hidden min-h-screen flex flex-col items-center justify-center px-4 text-center">
      <div class="max-w-2xl w-full">
        <div class="inline-flex items-center gap-2 bg-amber-400/10 text-amber-400 text-sm font-medium px-4 py-1.5 rounded-full mb-8">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          KI-Reputationsmanager für Restaurants
        </div>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6 leading-tight">
          Erfahren Sie, wie deutsche Gäste<br class="hidden md:block" />
          <span class="text-amber-400">Ihr Restaurant sehen.</span>
        </h1>
        <p class="text-xl text-slate-400 mb-10 max-w-xl mx-auto">
          Kostenloser KI-Reputations-Audit in 30 Sekunden. Finden Sie heraus, wie viele Gäste Sie durch schlechte Bewertungen verlieren.
        </p>
        <SearchWidget client:only="svelte" />
        <p class="mt-4 text-sm text-slate-500">Keine Registrierung erforderlich</p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         HERO 1 — Cookie-Saved (аудит выполнен, токена нет)
         Placeholder ROI + AI-симулятора. Полный виджет — Этап 5.
    ════════════════════════════════════════════════════════ -->
    <section id="hero-1" class="hidden min-h-screen flex flex-col items-center justify-center px-4 text-center">
      <div class="max-w-3xl w-full">
        <p class="text-slate-400 text-lg mb-2">Audit-Ergebnis für</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-8 text-amber-400" data-restaurant-name>Ihr Restaurant</h1>
        <AuditResult client:only="svelte" />
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         HERO 2 — Зарегистрирован, без интеграции Google Business
         Прогресс-бар онбординга. CTA → portal.vestamate.de/onboarding
    ════════════════════════════════════════════════════════ -->
    <section id="hero-2" class="hidden min-h-screen flex flex-col items-center justify-center px-4 text-center">
      <div class="max-w-lg w-full">
        <div class="text-5xl mb-6">👋</div>
        <h1 class="text-3xl md:text-4xl font-bold mb-1">Willkommen zurück,</h1>
        <p class="text-3xl md:text-4xl font-bold text-amber-400 mb-8" data-restaurant-name>Ihr Restaurant</p>

        <!-- Прогресс-бар онбординга: 3 шага -->
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 mb-8 text-left">
          <p class="text-xs text-slate-500 uppercase tracking-widest font-medium mb-6">Einrichtungsfortschritt</p>
          <div class="space-y-4">

            <!-- Шаг 1: выполнен -->
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <p class="font-medium text-slate-300">Schritt 1: Registrierung abgeschlossen</p>
            </div>

            <div class="ml-4 border-l border-slate-700 h-4"></div>

            <!-- Шаг 2: активный (pulse) -->
            <div class="flex items-start gap-4">
              <div class="relative w-8 h-8 rounded-full bg-amber-400 flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-50 animate-ping"></span>
                <span class="relative font-bold text-slate-950 text-sm">2</span>
              </div>
              <div>
                <p class="font-bold text-amber-400">Schritt 2 von 3: Google Business verbinden</p>
                <p class="text-sm text-slate-400 mt-0.5">Damit VestaMate auf Ihre Bewertungen zugreifen kann</p>
              </div>
            </div>

            <div class="ml-4 border-l border-slate-700 h-4"></div>

            <!-- Шаг 3: ещё не выполнен -->
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full bg-slate-800 border border-slate-600 flex items-center justify-center flex-shrink-0">
                <span class="text-slate-500 text-sm font-bold">3</span>
              </div>
              <p class="font-medium text-slate-500">Schritt 3: KI aktivieren &amp; loslegen</p>
            </div>

          </div>
        </div>

        <a
          href="https://portal.vestamate.de/onboarding"
          class="block w-full bg-amber-400 hover:bg-amber-300 text-slate-950 font-bold py-4 px-8 rounded-xl text-lg transition-colors duration-200"
        >
          Einrichtung fortsetzen →
        </a>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         HERO 3 — Активный клиент
         Дашборд-виджет. Данные из GET /api/status. CTA → portal.vestamate.de/dashboard
    ════════════════════════════════════════════════════════ -->
    <section id="hero-3" class="hidden min-h-screen flex flex-col items-center justify-center px-4 text-center">
      <div class="max-w-lg w-full">
        <div class="inline-flex items-center gap-2 bg-emerald-500/10 text-emerald-400 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          VestaMate aktiv
        </div>
        <h1 class="text-3xl md:text-4xl font-bold mb-1">Ihr Dashboard,</h1>
        <p class="text-3xl md:text-4xl font-bold text-amber-400 mb-8" data-restaurant-name>Ihr Restaurant</p>

        <!-- Дашборд: данные подгружаются из /api/status -->
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 mb-8 grid grid-cols-2 gap-4">
          <div class="bg-slate-800 rounded-xl p-5 text-left">
            <p class="text-sm text-slate-400 mb-1">Neue Bewertungen</p>
            <p class="text-xs text-slate-500 mb-3">letzte 7 Tage</p>
            <p id="status-reviews" class="text-4xl font-bold text-slate-100 animate-pulse">…</p>
          </div>
          <div class="bg-slate-800 rounded-xl p-5 text-left">
            <p class="text-sm text-slate-400 mb-1">KI-Status</p>
            <p class="text-xs text-slate-500 mb-3">letzte Antwort</p>
            <p id="status-ai" class="text-sm font-semibold text-emerald-400 animate-pulse">…</p>
          </div>
        </div>

        <a
          href="https://portal.vestamate.de/dashboard"
          class="block w-full bg-amber-400 hover:bg-amber-300 text-slate-950 font-bold py-4 px-8 rounded-xl text-lg transition-colors duration-200"
        >
          Dashboard öffnen →
        </a>
      </div>
    </section>

  </body>
</html>


